# API configuration
PORT=3000
WEB_ORIGIN=http://localhost:5173
JWT_SECRET=capstone-dev-secret
DEMO_MODE=true

# Sandbox KYC controls
# Comma-separated wallet addresses that should return PENDING or REJECTED in local demos.
KYC_REVIEW_WALLETS=
KYC_REJECTED_WALLETS=

# Persistence configuration
# Options: 'memory' (default), 'postgres'
PERSISTENCE_MODE=memory

# PostgreSQL connection options
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=pwn_shop
DB_SYNCHRONIZE=true
DB_MIGRATIONS_RUN=false

# Evidence storage
# Options: 'mock' (default), 'filesystem'
STORAGE_MODE=mock
STORAGE_LOCAL_DIR=.local-object-storage/evidence
STORAGE_MAX_BYTES=10485760

# Blockchain configuration
# Options: 'mock' (default), 'anvil'
BLOCKCHAIN_MODE=mock
ANVIL_RPC_URL=http://127.0.0.1:8545
